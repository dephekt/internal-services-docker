.vscode/
.cursor/
**/secrets/
keycloak-import/
keycloak-export/
core/keycloak-providers/keycloak-scripts.jar
core/tech-blog/
immich/.env
# Rendered from monitoring/apprise/monitoring.yaml.template by render-config.sh
# at inject-secrets time. Topic names live in 1Password to keep them out of
# the public repo (ntfy has no OIDC; topic names are the only access control).
monitoring/apprise/monitoring.yaml
# apprise-api runtime state (lands here only on the remote host via bind-mount;
# excluded so a rare local apprise-api run doesn't pollute the working tree).
monitoring/apprise/d0/
monitoring/apprise/store/
monitoring/apprise/.tmp_hc
cnotify/data/state.json

__pycache__/
.ruff_cache/
.venv/

# Pangolin: rendered from config.yml.template by render-config.sh
pangolin/config/config.yml
# Pangolin runtime state (lives only on the edge host via bind-mounts)
pangolin/config/db/
pangolin/config/letsencrypt/
pangolin/config/key
pangolin/config/GeoLite2-Country.mmdb
pangolin/config/logs/
pangolin/config/traefik/logs/
pangolin/config/openapi.yaml
.playwright-cli/
.playwright-mcp/

# understand-anything: the global ~/.gitignore blanket-ignores
# **/.understand-anything/**. Re-include only the durable knowledge graph
# state here; scratch dirs (.trash-*) stay ignored.
!.understand-anything/knowledge-graph.json
!.understand-anything/meta.json
!.understand-anything/config.json
!.understand-anything/fingerprints.json
!.understand-anything/.understandignore
!.understand-anything/intermediate/
!.understand-anything/intermediate/scan-result.json

