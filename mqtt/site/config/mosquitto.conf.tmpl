# Site broker — Daniel's local bus (grow/daniel-home/#). The site is an
# autonomous island: edge devices and the local grow-app + history-recorder all
# connect here. There is no central broker; remote access is handled at the app
# layer via Pangolin, not by bridging the bus.
listener 1883
allow_anonymous false
password_file /run/mosquitto/passwd
acl_file /run/mosquitto/acl

persistence true
persistence_location /mosquitto/data/
